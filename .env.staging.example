# BusFolia Premium - Staging Environment Configuration
# Copy this file to .env.staging and fill in the staging-specific values

# Database (Staging)
DATABASE_URL=mysql://user:password@staging-db:3306/busfolia_staging

# Stripe (Sandbox/Test Mode for Staging)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_test_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# OAuth (Staging)
VITE_APP_ID=staging_app_id
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://portal.manus.im

# Email (Staging - use test email service)
RESEND_API_KEY=re_test_...

# Manus Built-in APIs
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=staging_key_...
VITE_FRONTEND_FORGE_API_KEY=staging_frontend_key_...
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im

# JWT
JWT_SECRET=staging_jwt_secret_...

# Owner Info (Staging)
OWNER_NAME=BusFolia Staging
OWNER_OPEN_ID=staging_owner_id

# Analytics (Staging)
VITE_ANALYTICS_WEBSITE_ID=staging_analytics_id
VITE_ANALYTICS_ENDPOINT=https://staging-analytics.example.com

# App Info
VITE_APP_TITLE=BusFolia Premium (Staging)
VITE_APP_LOGO=https://cdn.example.com/logo-staging.png

# Staging-specific flags
NODE_ENV=staging
DEBUG=true
